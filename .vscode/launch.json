{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Project Pulse Dashboard",
      "type": "python",
      "request": "launch",
      "module": "http.server",
      "args": [
        "5500"
      ],
      "cwd": "${workspaceFolder}/app",
      "console": "integratedTerminal",
      "runtimeExecutable": "python3",
      "serverReadyAction": {
        "pattern": "Serving HTTP on",
        "uriFormat": "http://localhost:%s/index.html",
        "action": "openExternally"
      }
    }
  ]
}
